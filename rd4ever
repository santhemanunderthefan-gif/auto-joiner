-- CREW SYNC MASTER SCRIPT (FINAL)
-- Website: https://rd4ever.onrender.com
-- Joins Pirates IMMEDIATELY, then waits for START command to accept crew invites

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInput = game:GetService("VirtualInputManager")
local HttpService = game:GetService("HttpService")
local player = Players.LocalPlayer

-- ========== CONFIGURATION ==========
local WEBSITE_URL = "https://rd4ever.onrender.com"
local TOP_BAR_OFFSET = 58
local DEVICE_NAME = player.Name .. "_" .. tostring(player.UserId):sub(1,4)

-- ========== PART 1: AUTO JOIN PIRATES (RUNS IMMEDIATELY) ==========
local function joinPirates()
    repeat task.wait() until game:IsLoaded()
    
    local success, result = pcall(function()
        local commF = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommF_")
        return commF:InvokeServer("SetTeam", "Pirates")
    end)
    
    if success then
        print("✅ [PIRATES] Successfully joined Pirates team!")
        return true
    else
        warn("❌ [PIRATES] Failed: " .. tostring(result))
        return false
    end
end

-- JOIN PIRATES RIGHT NOW
print("🏴‍☠️ Joining Pirates team immediately...")
local joinedPirates = joinPirates()

-- ========== PART 2: AUTO ACCEPT CREW INVITE (WAITS FOR START) ==========
local function findAndAcceptCrewInvite()
    local btnPaths = {
        "Main.Crew.Create.Invite.Accept",
        "Main.Crew.Invite.Accept",
        "Crew.Invite.Accept",
        "Main.Dialog.Confirm"
    }
    
    for _, path in ipairs(btnPaths) do
        local success, btn = pcall(function()
            local current = player.PlayerGui
            for part in path:gmatch("[^%.]+") do
                current = current[part]
                if not current then break end
            end
            return current
        end)
        
        if success and btn and btn:IsA("TextButton") and btn.Visible and btn.AbsolutePosition then
            local x = btn.AbsolutePosition.X + (btn.AbsoluteSize.X / 2)
            local y = btn.AbsolutePosition.Y + (btn.AbsoluteSize.Y / 2) + TOP_BAR_OFFSET
            
            VirtualInput:SendMouseMoveEvent(x, y, 0, game)
            task.wait(0.05)
            VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
            task.wait(0.1)
            VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
            
            print("✅ [CREW] Accepted crew invite!")
            return true
        end
    end
    
    return false
end

-- ========== PART 3: WEBSITE COMMUNICATION ==========
local function sendStatusToWebsite(status, extra)
    local success, err = pcall(function()
        local data = HttpService:JSONEncode({
            device = DEVICE_NAME,
            status = status,
            team = player.Team and player.Team.Name or "Pirates",
            joined_pirates = joinedPirates,
            accepted_invite = extra or false,
            player_name = player.Name,
            user_id = player.UserId,
            timestamp = os.time()
        })
        HttpService:PostAsync(WEBSITE_URL .. "/api/status", data, Enum.HttpContentType.ApplicationJson)
    end)
    if not success then
        warn("Failed to send status: " .. tostring(err))
    end
end

-- Register device with website
local function registerWithWebsite()
    local success, err = pcall(function()
        local data = HttpService:JSONEncode({
            device = DEVICE_NAME,
            player_name = player.Name,
            user_id = player.UserId
        })
        HttpService:PostAsync(WEBSITE_URL .. "/api/register", data, Enum.HttpContentType.ApplicationJson)
    end)
    if success then
        print("✅ Registered with website: " .. DEVICE_NAME)
    else
        warn("⚠️ Failed to register: " .. tostring(err))
    end
end

-- Poll website for START command (for crew invites only)
local function waitForStartCommand()
    while true do
        task.wait(1)  -- Check every second
        
        local success, response = pcall(function()
            return HttpService:GetAsync(WEBSITE_URL .. "/api/command/" .. player.UserId, true)
        end)
        
        if success and response then
            local data = HttpService:JSONDecode(response)
            
            if data.command == "START_SYNC" then
                print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
                print("🎯 START COMMAND RECEIVED FROM WEBSITE!")
                print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
                
                -- ONLY accept crew invite (already joined pirates)
                local crewSuccess = findAndAcceptCrewInvite()
                
                -- Send result back to website
                sendStatusToWebsite("completed", crewSuccess)
                
                print("📊 Crew Invite: " .. (crewSuccess and "✓ ACCEPTED" or "✗ NOT FOUND"))
                
                -- Wait a bit before accepting new commands
                task.wait(5)
            end
        end
    end
end

