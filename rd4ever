    print("   Dashboard: " .. DASHBOARD_URL)
    print("   Server: " .. getServerCode())
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    
    -- Register with dashboard (retry until success)
    repeat
        task.wait(2)
    until registerDevice()
    
    -- Start main async loop
    spawn(function()
        while true do
            task.wait(0.5)
            
            -- Check for invites
            holdInvite()
            
            -- Check for sync signal every second
            if tick() % 1 < 0.5 then
                checkSyncSignal()
            end
            
            -- Perform synced accept
            performSyncedAccept()
            
            -- Send status every 5 seconds
            if tick() - lastStatusUpdate >= 5 then
                sendStatusToDashboard()
                lastStatusUpdate = tick()
            end
            
            -- Anti-AFK
            antiAFK()
        end
    end)
end

