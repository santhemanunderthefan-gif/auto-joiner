-- ========== CONFIGURATION ==========
local DASHBOARD_URL = "https://rd4ever.onrender.com"  -- YOUR LIVE DASHBOARD
local DEVICE_NAME = player.Name .. "_" .. tostring(player.UserId)
local useHttpPolling = false
local SOCKET_CONNECTION = nil

-- State variables
local hasPendingInvite = false
local acceptButton = nil
local syncActive = false
local currentTargetTime = nil
local hasJoinedPirate = false
local currentServerCode = nil

-- Anti-AFK
local antiAFKEnabled = true
local lastAFKAction = 0

-- ========== GET CURRENT SERVER CODE ==========
local function getServerCode()
    local jobId = game.JobId
    if jobId and jobId ~= "" then
        return jobId
    end
    return tostring(game.PlaceId) .. "_" .. tostring(math.random(10000, 99999))
end

-- ========== JOIN PIRATE TEAM ON STARTUP ==========
local function joinPirateTeam()
    if hasJoinedPirate then return true end
    
    print("🏴‍☠️ Joining Pirate team...")
    
    for attempt = 1, 10 do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            local function findPirateButton(obj)
                for _, child in pairs(obj:GetChildren()) do
                    if child:IsA("TextButton") then
                        local text = (child.Text or ""):lower()
                        if text:find("pirate") then
                            return child
                        end
                    end
                    local found = findPirateButton(child)
                    if found then return found end
                end
                return nil
            end
            
            local pirateButton = findPirateButton(playerGui)
            if pirateButton then
                pcall(function()
                    pirateButton:Fire("MouseButton1Click")
                    pirateButton:Click()
                end)
                hasJoinedPirate = true
                print("✅ Joined Pirate team!")
                return true
            end
        end
        task.wait(1)
    end
    
    print("⚠️ Already in Pirate team or button not found")
    hasJoinedPirate = true
    return true
end

-- ========== DETECT CREW INVITE ==========
local function detectCrewInvite()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local function searchForInvite(obj)
        for _, child in pairs(obj:GetChildren()) do
            if child:IsA("TextButton") then
                local text = (child.Text or ""):lower()
                if text:find("accept") or text:find("join") then
                    local parent = child.Parent
                    local parentText = ""
                    if parent and parent:IsA("Frame") then
                        for _, sibling in pairs(parent:GetChildren()) do
                            if sibling:IsA("TextLabel") then
                                parentText = parentText .. (sibling.Text or ""):lower()
                            end
                        end
                    end
                    if parentText:find("invite") or parentText:find("crew") then
                        return child
                    end
                end
            end
            local found = searchForInvite(child)
            if found then return found end
        end
        return nil
    end
    
    return searchForInvite(playerGui)
end

-- ========== HOLD INVITE ==========
local function holdInvite()
    local button = detectCrewInvite()
    if button and not hasPendingInvite then
        hasPendingInvite = true
        acceptButton = button
        print("📨 CREW INVITE DETECTED! Waiting for START signal...")
        
        -- Visual feedback
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            local gui = Instance.new("ScreenGui")
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
            frame.BackgroundTransparency = 0.8
            frame.Parent = gui
            gui.Parent = playerGui
            task.wait(0.3)
            gui:Destroy()
        end
    end
    return hasPendingInvite
end

-- ========== ACCEPT INVITE (SYNCED) ==========
local function acceptInvite()
    if not acceptButton then
        acceptButton = detectCrewInvite()
    end
    
    if acceptButton then
        pcall(function()
            acceptButton:Fire("MouseButton1Click")
            acceptButton:Click()
        end)
        print("✅ CREW INVITE ACCEPTED at " .. os.date("%H:%M:%S"))
        hasPendingInvite = false
        acceptButton = nil
        
        -- Success notification
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            local gui = Instance.new("ScreenGui")
            local frame = Instance.new("Frame")
            local label = Instance.new("TextLabel")
            
            frame.Size = UDim2.new(0, 250, 0, 50)
            frame.Position = UDim2.new(0.5, -125, 0.8, 0)
            frame.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            frame.BackgroundTransparency = 0.3
            
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.Text = "✅ Joined Crew!"
            label.TextScaled = true
            
            label.Parent = frame
            frame.Parent = gui
            gui.Parent = playerGui
            task.wait(2)
            gui:Destroy()
        end
        return true
    end
    return false
end

-- ========== SYNC EXECUTION ==========
local function performSyncedAccept()
    if not syncActive or not currentTargetTime then return end
    
    local timeLeft = currentTargetTime - tick()
    
    if timeLeft <= 0 then
        for i = 1, 5 do
            acceptInvite()
            task.wait(0.01)
        end
        syncActive = false
        currentTargetTime = nil
    end
end

-- ========== ANTI-AFK (Mobile Optimized) ==========
local function antiAFK()
    if not antiAFKEnabled then return end
    
    local now = tick()
    if now - lastAFKAction < 60 then return end
    
    local character = player.Character
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    if humanoid then
        pcall(function()
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end)
        lastAFKAction = now
        print("🦘 Anti-AFK: Jumped")
    end
end

-- ========== SEND STATUS TO DASHBOARD ==========
local function sendStatusToDashboard()
    currentServerCode = getServerCode()
    
    local statusData = {
        device = DEVICE_NAME,
        server_code = currentServerCode,
        has_invite = hasPendingInvite,
        joined_pirate = hasJoinedPirate,
        timestamp = os.time()
    }
    
    if SOCKET_CONNECTION and not useHttpPolling then
        pcall(function()
            SOCKET_CONNECTION:emit("update_status", statusData)
        end)
    elseif useHttpPolling then
        pcall(function()
            HttpService:PostAsync(DASHBOARD_URL .. "/api/update_status",
                HttpService:JSONEncode(statusData),
                Enum.HttpContentType.ApplicationJson)
        end)
    end
    
    print("📡 Status - Server: " .. string.sub(currentServerCode, 1, 15) .. "... | Invite: " .. (hasPendingInvite and "YES" or "NO"))
end

-- ========== WEBSOCKET SETUP ==========
local function setupWebSocket()
    local success, socket = pcall(function()
        local socketio = require(ReplicatedStorage:WaitForChild("SocketIO"))
        if not socketio then
            error("SocketIO not found")
        end
        return socketio.connect(DASHBOARD_URL)
    end)
    
    if not success then
        useHttpPolling = true
        print("⚠️ WebSocket unavailable, using HTTP polling mode")
        startMainLoop()
        return
    end
    
    SOCKET_CONNECTION = socket
    
    SOCKET_CONNECTION:on("connect", function()
        print("✅ Connected to dashboard: " .. DASHBOARD_URL)
        SOCKET_CONNECTION:emit("register", {device = DEVICE_NAME})
        SOCKET_CONNECTION:emit("request_approval", {device = DEVICE_NAME})
        task.wait(1)
        sendStatusToDashboard()
    end)
    
    SOCKET_CONNECTION:on("click_at", function(data)
        if hasPendingInvite then
            print("🎯 START SIGNAL! Accepting invite...")
            currentTargetTime = data.target_time
            syncActive = true
        else
            print("⚠️ START signal but NO pending invite!")
        end
    end)
    
    SOCKET_CONNECTION:on("stop_clicking", function()
        syncActive = false
        currentTargetTime = nil
        print("🛑 Sync stopped")
    end)
    
    SOCKET_CONNECTION:on("approval_granted", function()
        print("✅ Device approved!")
    end)
    
    SOCKET_CONNECTION:emit("request_approval", {device = DEVICE_NAME})
end

-- ========== HTTP POLLING FALLBACK ==========
local function httpPollingLoop()
    while useHttpPolling do
        task.wait(1)
        
        local success, response = pcall(function()
            return HttpService:GetAsync(DASHBOARD_URL .. "/api/sync_status", true)
        end)
        
        if success and response then
            local data = HttpService:JSONDecode(response)
            if data.sync_active and data.target_time > tick() and hasPendingInvite then
                currentTargetTime = data.target_time
                syncActive = true
                print("🎯 Sync via HTTP!")
            end
        end
        
        if tick() % 3 < 1 then
            sendStatusToDashboard()
        end
    end
end

-- ========== MAIN LOOP ==========
local function startMainLoop()
    print("🚀 GLITCHER ACTIVE")
    print("   Device: " .. DEVICE_NAME)
    print("   Dashboard: " .. DASHBOARD_URL)
    print("   Server: " .. getServerCode())
    print("")
    print("⏳ Waiting for crew invite...")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    
    if useHttpPolling then
        spawn(httpPollingLoop)
    end
    
    spawn(function()
        while true do
            task.wait(0.5)
            holdInvite()
            if tick() % 3 < 0.5 and not useHttpPolling then
                sendStatusToDashboard()
            end
            performSyncedAccept()
            antiAFK()
        end
    end)
end

