-- ============================================
-- PIRATE KING GLITCH - CLICKS THE NPC
-- The red NPC below "PIRATES" text is the target
-- ============================================

local player = game.Players.LocalPlayer
local HttpService = game:GetService("HttpService")
local VirtualInput = game:GetService("VirtualInputManager")

local DASHBOARD_URL = "https://rd4ever.onrender.com"
local DEVICE_NAME = player.Name .. "_" .. tostring(player.UserId)
local syncActive = false
local targetTime = nil
local overlay = nil

-- ========== CLICK THE PIRATE NPC ==========
local function clickPirateNPC()
    print("[PK] Looking for Pirate NPC...")
    
    -- Find all NPCs in the game
    local function findPirateNPC()
        -- Check workspace for NPCs
        local npc = nil
        
        -- Method 1: Look for NPC by name
        for _, child in pairs(workspace:GetChildren()) do
            if child:IsA("Model") then
                local name = (child.Name or ""):lower()
                if name:find("pirate") or name:find("npc") then
                    -- Find humanoid or clickable part
                    local humanoid = child:FindFirstChild("Humanoid")
                    local head = child:FindFirstChild("Head")
                    if humanoid and head then
                        return child
                    end
                end
            end
        end
        
        -- Method 2: Look for NPC by position (Pirate NPC is usually on left side)
        for _, child in pairs(workspace:GetChildren()) do
            if child:IsA("Model") and child:FindFirstChild("Humanoid") then
                local rootPart = child:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local pos = rootPart.Position
                    -- Pirate NPC is typically on left side (negative X)
                    if pos.X < 0 then
                        return child
                    end
                end
            end
        end
        
        return nil
    end
    
    local pirateNPC = findPirateNPC()
    
    if pirateNPC then
        print("[PK] Found Pirate NPC: " .. pirateNPC.Name)
        
        -- Get the NPC's position on screen
        local rootPart = pirateNPC:FindFirstChild("HumanoidRootPart") or pirateNPC:FindFirstChild("Head")
        if rootPart then
            local screenPos = workspace.CurrentCamera:WorldToViewportPoint(rootPart.Position)
            if screenPos then
                local x, y = screenPos.X, screenPos.Y
                print("[PK] NPC screen position: " .. x .. ", " .. y)
                
                -- Click at that position
                VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
                task.wait(0.05)
                VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
                print("[PK] Clicked Pirate NPC!")
                return true
            end
        end
    else
        print("[PK] Pirate NPC not found - trying alternative method")
        
        -- Alternative: Click at known screen position (left side where NPC stands)
        local x, y = 300, 400  -- Adjust these coordinates
        VirtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        VirtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
        print("[PK] Clicked at position: " .. x .. ", " .. y)
        return true
    end
    
    return false
end

-- ========== CLICK JOIN BUTTON (For crew invite) ==========
local function clickJoinButton()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    local function findJoinButton(obj)
        for _, child in pairs(obj:GetChildren()) do
            if child:IsA("ImageButton") then
                local textLabel = child:FindFirstChild("TextLabel")
                if textLabel and textLabel.Text then
                    local text = textLabel.Text:lower()
                    if text:find("join") then
                        return child
                    end
                end
            end
            if child:IsA("TextButton") then
                local text = (child.Text or ""):lower()
                if text:find("join") then
                    return child
                end
            end
            local found = findJoinButton(child)
            if found then return found end
        end
        return nil
    end
    
    local joinButton = findJoinButton(playerGui)
    
    if joinButton then
        joinButton:Fire("MouseButton1Click")
        joinButton:Click()
        print("[PK] Clicked JOIN!")
        return true
    end
    return false
end

-- ========== CHECK IF INVITE EXISTS ==========
local function hasInvite()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    for _, child in pairs(playerGui:GetDescendants()) do
        if child:IsA("TextLabel") then
            local text = (child.Text or ""):lower()
            if text:find("crew invite") or text:find("invite") then
                return true
            end
        end
    end
    return false
end

-- ========== CREATE WHITE OVERLAY ==========
local function createWhiteOverlay()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "PK_Overlay"
    screenGui.ResetOnSpawn = false
    
    local whiteFrame = Instance.new("Frame")
    whiteFrame.Size = UDim2.new(1, 0, 1, 0)
    whiteFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    whiteFrame.BackgroundTransparency = 0
    whiteFrame.BorderSizePixel = 0
    whiteFrame.Parent = screenGui
    
    screenGui.Parent = player:WaitForChild("PlayerGui")
    return screenGui
end

-- ========== REGISTER WITH DASHBOARD ==========
local function registerDevice()
    local data = {
        device = DEVICE_NAME,
        server_code = game.JobId,
        has_invite = false,
        timestamp = os.time()
    }
    
    pcall(function()
        HttpService:PostAsync(
            DASHBOARD_URL .. "/api/register_device",
            HttpService:JSONEncode(data),
            Enum.HttpContentType.ApplicationJson
        )
    end)
    print("[PK] Registered: " .. DEVICE_NAME)
end

-- ========== CHECK SYNC SIGNAL ==========
local function checkSyncSignal()
    local success, response = pcall(function()
        return HttpService:GetAsync(DASHBOARD_URL .. "/api/sync_status", true)
    end)
    
    if success and response then
        local data = HttpService:JSONDecode(response)
        if data.sync_active and data.target_time then
            if data.target_time > tick() then
                if not syncActive then
                    print("[PK] START signal received!")
                    targetTime = data.target_time
                    syncActive = true
                end
            end
        end
    end
end

-- ========== MAIN ==========
print("[PK] Pirate King Glitch - NPC Click Method")

-- Wait for game to load
repeat task.wait(1) until player.Character and player.Character:FindFirstChild("Humanoid")
task.wait(2)

-- Click the Pirate NPC to join team
clickPirateNPC()
task.wait(2)

-- Register with dashboard
registerDevice()

-- Wait for crew invite
print("[PK] Waiting for crew invite...")
repeat
    task.wait(1)
until hasInvite()

print("[PK] Crew invite detected!")

-- Create white overlay
overlay = createWhiteOverlay()
print("[PK] White overlay active")

-- Wait for START signal
print("[PK] Waiting for START signal...")

while true do
    checkSyncSignal()
    
    if syncActive and targetTime then
        local timeLeft = targetTime - tick()
        
        if timeLeft <= 0 then
            print("[PK] EXECUTING SYNC CLICK!")
            
            for i = 1, 3 do
                clickJoinButton()
                task.wait(0.05)
            end
            
            print("[PK] JOIN clicked!")
            task.wait(1)
            pcall(function() overlay:Destroy() end)
            print("[PK] Complete!")
            break
        end
    end
    
    task.wait(0.1)
end
