-- ============================================
-- PIRATE KING GLITCH - COMPLETE SCRIPT
-- White overlay | Auto-join Pirates | Sync JOIN
-- ============================================

local player = game.Players.LocalPlayer
local HttpService = game:GetService("HttpService")
local VirtualInput = game:GetService("VirtualInputManager")

-- ========== CONFIGURATION ==========
local DASHBOARD_URL = "https://rd4ever.onrender.com"
local DEVICE_NAME = player.Name .. "_" .. tostring(player.UserId)
local syncActive = false
local targetTime = nil

-- ========== CREATE WHITE OVERLAY ==========
local function createWhiteOverlay()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "PK_Overlay"
    screenGui.ResetOnSpawn = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    local whiteFrame = Instance.new("Frame")
    whiteFrame.Size = UDim2.new(1, 0, 1, 0)
    whiteFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    whiteFrame.BackgroundTransparency = 0
    whiteFrame.BorderSizePixel = 0
    whiteFrame.Parent = screenGui
    
    -- Small status text in corner
    local statusText = Instance.new("TextLabel")
    statusText.Size = UDim2.new(0, 150, 0, 30)
    statusText.Position = UDim2.new(0, 10, 1, -40)
    statusText.BackgroundTransparency = 1
    statusText.Text = "PK GLITCH READY"
    statusText.TextColor3 = Color3.fromRGB(0, 0, 0)
    statusText.TextSize = 14
    statusText.TextXAlignment = Enum.TextXAlignment.Left
    statusText.Parent = screenGui
    
    screenGui.Parent = player:WaitForChild("PlayerGui")
    return screenGui
end

-- ========== AUTO-JOIN PIRATES (KEEPS CLICKING UNTIL SUCCESS) ==========
local function joinPirates()
    print("[PK] Auto-joining Pirates...")
    
    local maxAttempts = 50
    local joined = false
    
    for attempt = 1, maxAttempts do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            -- Search for Pirates button
            local function findPirateButton(obj)
                for _, child in pairs(obj:GetChildren()) do
                    -- Check ImageButton (main UI type)
                    if child:IsA("ImageButton") then
                        local textLabel = child:FindFirstChild("TextLabel")
                        if textLabel and textLabel.Text then
                            local text = textLabel.Text:upper()
                            if text:find("PIRATE") or text:find("PIRATES") then
                                return child
                            end
                        end
                    end
                    -- Check TextButton
                    if child:IsA("TextButton") then
                        local text = (child.Text or ""):upper()
                        if text:find("PIRATE") or text:find("PIRATES") then
                            return child
                        end
                    end
                    local found = findPirateButton(child)
                    if found then return found end
                end
                return nil
            end
            
            local pirateButton = findPirateButton(playerGui)
            if pirateButton then
                -- Click the button
                pirateButton:Fire("MouseButton1Click")
                pirateButton:Click()
                print("[PK] Clicked Pirates button (attempt " .. attempt .. ")")
                joined = true
                break
            end
        end
        task.wait(0.5)
    end
    
    if joined then
        print("[PK] ✅ Successfully joined Pirates!")
        -- Wait a moment for team selection to register
        task.wait(2)
    else
        print("[PK] ⚠️ Could not find Pirates button - may already be in team")
    end
    
    return joined
end

-- ========== FIND AND CLICK JOIN BUTTON ==========
local function clickJoinButton()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    local function findJoinButton(obj)
        for _, child in pairs(obj:GetChildren()) do
            -- Check ImageButton with TextLabel
            if child:IsA("ImageButton") then
                local textLabel = child:FindFirstChild("TextLabel")
                if textLabel and textLabel.Text then
                    local text = textLabel.Text:lower()
                    if text:find("join") then
                        return child
                    end
                end
            end
            -- Check TextButton
            if child:IsA("TextButton") then
                local text = (child.Text or ""):lower()
                if text:find("join") then
                    return child
                end
            end
            local found = findJoinButton(child)
            if found then return found end
        end
        return nil
    end
    
    local joinButton = findJoinButton(playerGui)
    
    if joinButton then
        joinButton:Fire("MouseButton1Click")
        joinButton:Click()
        print("[PK] ✅ Clicked JOIN button!")
        return true
    end
    return false
end

-- ========== CHECK IF INVITE EXISTS ==========
local function hasInvite()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    for _, child in pairs(playerGui:GetDescendants()) do
        if child:IsA("TextLabel") then
            local text = (child.Text or ""):lower()
            if text:find("crew invite") or text:find("invite") then
                return true
            end
        end
        if child:IsA("TextButton") then
            local text = (child.Text or ""):lower()
            if text:find("join") then
                return true
            end
        end
    end
    return false
end

-- ========== REGISTER WITH DASHBOARD ==========
local function registerDevice()
    local serverCode = game.JobId
    local data = {
        device = DEVICE_NAME,
        server_code = serverCode,
        has_invite = false,
        joined_pirate = true,
        timestamp = os.time()
    }
    
    pcall(function()
        HttpService:PostAsync(
            DASHBOARD_URL .. "/api/register_device",
            HttpService:JSONEncode(data),
            Enum.HttpContentType.ApplicationJson
        )
    end)
    print("[PK] ✅ Registered with dashboard: " .. DEVICE_NAME)
    print("[PK] 📍 Server: " .. serverCode)
end

-- ========== UPDATE INVITE STATUS ==========
local function updateInviteStatus(hasInvite)
    pcall(function()
        HttpService:PostAsync(
            DASHBOARD_URL .. "/api/update_status",
            HttpService:JSONEncode({
                device = DEVICE_NAME,
                has_invite = hasInvite,
                timestamp = os.time()
            }),
            Enum.HttpContentType.ApplicationJson
        )
    end)
end

-- ========== CHECK SYNC SIGNAL ==========
local function checkSyncSignal()
    local success, response = pcall(function()
        return HttpService:GetAsync(DASHBOARD_URL .. "/api/sync_status", true)
    end)
    
    if success and response then
        local data = HttpService:JSONDecode(response)
        if data.sync_active and data.target_time then
            if data.target_time > tick() then
                if not syncActive then
                    print("[PK] 🎯 START SIGNAL received!")
                    targetTime = data.target_time
                    syncActive = true
                end
            end
        end
    end
end

-- ========== REMOVE OVERLAY ==========
local function removeOverlay(overlay)
    pcall(function() overlay:Destroy() end)
    print("[PK] Overlay removed")
end

-- ========== MAIN ==========
print("[PK] ╔════════════════════════════════════════╗")
print("[PK] ║  PIRATE KING GLITCH - SYNC MACHINE    ║")
print("[PK] ║  White Overlay | Auto Pirates | Sync  ║")
print("[PK] ╚════════════════════════════════════════╝")

-- Create white overlay
local overlay = createWhiteOverlay()
print("[PK] ✅ White overlay active")

-- Wait for game to load
repeat task.wait(1) until player.Character and player.Character:FindFirstChild("Humanoid")
task.wait(2)

-- Auto-join Pirates
joinPirates()

-- Register with dashboard
registerDevice()

-- Wait for crew invite
print("[PK] 📨 Waiting for crew invite...")
repeat
    task.wait(1)
until hasInvite()

print("[PK] ✅ Crew invite detected!")
updateInviteStatus(true)

-- Wait for START signal
print("[PK] 🎯 Waiting for START signal from dashboard...")

-- Sync loop
while true do
    checkSyncSignal()
    
    if syncActive and targetTime then
        local timeLeft = targetTime - tick()
        
        if timeLeft <= 0 then
            print("[PK] 🔥 EXECUTING SYNC CLICK!")
            
            -- Click JOIN multiple times for reliability
            for i = 1, 3 do
                clickJoinButton()
                task.wait(0.05)
            end
            
            print("[PK] ✅ JOIN clicked! Removing overlay...")
            task.wait(1)
            removeOverlay(overlay)
            print("[PK] 🎉 Complete! Crew joined successfully!")
            break
        elseif timeLeft <= 1 then
            print("[PK] Syncing in " .. string.format("%.1f", timeLeft) .. "s...")
        end
    end
    
    task.wait(0.1)
end
