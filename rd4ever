-- ========== CONFIGURATION ==========
local DASHBOARD_URL = "https://rd4ever.onrender.com"
local DEVICE_NAME = player.Name .. "_" .. tostring(player.UserId)
local hasPendingInvite = false
local acceptButton = nil
local syncActive = false
local currentTargetTime = nil
local hasJoinedPirate = false
local currentServerCode = nil
local lastAFKAction = 0
local lastStatusUpdate = 0
local registered = false

-- ========== GET CURRENT SERVER CODE ==========
local function getServerCode()
    local jobId = game.JobId
    if jobId and jobId ~= "" then
        return jobId
    end
    return tostring(game.PlaceId) .. "_" .. tostring(math.random(10000, 99999))
end

-- ========== JOIN PIRATE TEAM (FAST & RELIABLE) ==========
local function joinPirateTeam()
    if hasJoinedPirate then return true end
    
    print("🏴‍☠️ Looking for Pirate/Marine selection screen...")
    
    local startTime = tick()
    local maxWait = 10
    
    -- Keep checking until found or timeout
    repeat
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            -- Search for any Pirate button
            local function findPirateButton(obj)
                for _, child in pairs(obj:GetChildren()) do
                    if child:IsA("TextButton") then
                        local text = (child.Text or ""):lower()
                        if text:find("pirate") then
                            return child
                        end
                    end
                    local found = findPirateButton(child)
                    if found then return found end
                end
                return nil
            end
            
            local pirateButton = findPirateButton(playerGui)
            if pirateButton then
                pcall(function()
                    pirateButton:Fire("MouseButton1Click")
                    pirateButton:Click()
                end)
                hasJoinedPirate = true
                print("✅ Joined Pirate team!")
                
                -- Visual confirmation
                local gui = Instance.new("ScreenGui")
                local frame = Instance.new("Frame")
                local label = Instance.new("TextLabel")
                gui.Name = "PirateJoinConfirm"
                frame.Size = UDim2.new(0, 200, 0, 50)
                frame.Position = UDim2.new(0.5, -100, 0.3, 0)
                frame.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                frame.BackgroundTransparency = 0.5
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = "🏴‍☠️ JOINED PIRATES! 🏴‍☠️"
                label.TextColor3 = Color3.fromRGB(255, 255, 255)
                label.TextScaled = true
                label.Parent = frame
                frame.Parent = gui
                gui.Parent = playerGui
                task.wait(2)
                gui:Destroy()
                return true
            end
        end
        task.wait(0.2)
    until tick() - startTime > maxWait
    
    print("⚠️ Pirate button not found - may already be in a team")
    hasJoinedPirate = true
    return true
end

-- ========== DETECT CREW INVITE ==========
local function detectCrewInvite()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local function searchForInvite(obj)
        for _, child in pairs(obj:GetChildren()) do
            if child:IsA("TextButton") then
                local text = (child.Text or ""):lower()
                if text:find("accept") or text:find("join") then
                    local parent = child.Parent
                    if parent then
                        for _, sibling in pairs(parent:GetChildren()) do
                            if sibling:IsA("TextLabel") then
                                local siblingText = (sibling.Text or ""):lower()
                                if siblingText:find("invite") or siblingText:find("crew") then
                                    return child
                                end
                            end
                        end
                    end
                    return child
                end
            end
            local found = searchForInvite(child)
            if found then return found end
        end
        return nil
    end
    
    return searchForInvite(playerGui)
end

-- ========== HOLD INVITE ==========
local function holdInvite()
    local button = detectCrewInvite()
    if button and not hasPendingInvite then
        hasPendingInvite = true
        acceptButton = button
        print("📨 CREW INVITE DETECTED! Waiting for START signal...")
        
        -- Visual feedback
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            local gui = Instance.new("ScreenGui")
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 1, 0)
            frame.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
            frame.BackgroundTransparency = 0.7
            frame.Parent = gui
            gui.Parent = playerGui
            task.wait(0.5)
            gui:Destroy()
        end
    end
    return hasPendingInvite
end

-- ========== ACCEPT INVITE ==========
local function acceptInvite()
    if not acceptButton then
        acceptButton = detectCrewInvite()
    end
    
    if acceptButton then
        pcall(function()
            acceptButton:Fire("MouseButton1Click")
            acceptButton:Click()
        end)
        print("✅ CREW INVITE ACCEPTED at " .. os.date("%H:%M:%S"))
        hasPendingInvite = false
        acceptButton = nil
        
        -- Success notification
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui then
            local gui = Instance.new("ScreenGui")
            local frame = Instance.new("Frame")
            local label = Instance.new("TextLabel")
            frame.Size = UDim2.new(0, 250, 0, 50)
            frame.Position = UDim2.new(0.5, -125, 0.7, 0)
            frame.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            frame.BackgroundTransparency = 0.3
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = "✅ JOINED CREW! ✅"
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.TextScaled = true
            label.Parent = frame
            frame.Parent = gui
            gui.Parent = playerGui
            task.wait(2)
            gui:Destroy()
        end
        return true
    end
    return false
end

-- ========== CHECK SYNC SIGNAL FROM DASHBOARD ==========
local function checkSyncSignal()
    local success, response = pcall(function()
        return HttpService:GetAsync(DASHBOARD_URL .. "/api/sync_status", true)
    end)
    
    if success and response then
        local data = HttpService:JSONDecode(response)
        if data.sync_active and data.target_time then
            if data.target_time > tick() and hasPendingInvite then
                if not syncActive then
                    print("🎯 START SIGNAL received! Accepting invite in sync...")
                    currentTargetTime = data.target_time
                    syncActive = true
                end
            end
        end
    end
end

-- ========== PERFORM SYNCED ACCEPT ==========
local function performSyncedAccept()
    if not syncActive or not currentTargetTime then return end
    
    local timeLeft = currentTargetTime - tick()
    
    if timeLeft <= 0 then
        -- BURST ACCEPT: 5 rapid attempts
        for i = 1, 5 do
            acceptInvite()
            task.wait(0.01)
        end
        syncActive = false
        currentTargetTime = nil
        print("✅ Sync complete! Crew joined successfully!")
    elseif timeLeft <= 1 and timeLeft > 0 then
        -- Pre-warning
        print("⚡ Sync imminent! Ready to accept invite...")
    end
end

-- ========== REGISTER DEVICE WITH DASHBOARD ==========
local function registerDevice()
    if registered then return true end
    
    currentServerCode = getServerCode()
    
    local registerData = {
        device = DEVICE_NAME,
        server_code = currentServerCode,
        has_invite = false,
        joined_pirate = hasJoinedPirate,
        action = "register"
    }
    
    local success = pcall(function()
        HttpService:PostAsync(
            DASHBOARD_URL .. "/api/register_device",
            HttpService:JSONEncode(registerData),
            Enum.HttpContentType.ApplicationJson
        )
    end)
    
    if success then
        registered = true
        print("✅ Registered with dashboard: " .. DEVICE_NAME)
        print("📍 Server Code: " .. currentServerCode)
        return true
    else
        print("❌ Failed to register - retrying...")
        return false
    end
end

-- ========== SEND STATUS TO DASHBOARD ==========
local function sendStatusToDashboard()
    currentServerCode = getServerCode()
    
    local statusData = {
        device = DEVICE_NAME,
        server_code = currentServerCode,
        has_invite = hasPendingInvite,
        joined_pirate = hasJoinedPirate,
        timestamp = os.time()
    }
    
    pcall(function()
        HttpService:PostAsync(
            DASHBOARD_URL .. "/api/update_status",
            HttpService:JSONEncode(statusData),
            Enum.HttpContentType.ApplicationJson
        )
    end)
end

-- ========== ANTI-AFK (ADVANCED) ==========
local function antiAFK()
    local now = tick()
    if now - lastAFKAction < 45 then return end
    
    local character = player.Character
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    if humanoid then
        -- Random anti-AFK action
        local action = math.random(1, 3)
        
        if action == 1 then
            -- Jump
            pcall(function()
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end)
            print("🦘 Anti-AFK: Jumped")
        elseif action == 2 then
            -- Small movement (if in game)
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local oldPos = rootPart.Position
                pcall(function()
                    rootPart.CFrame = rootPart.CFrame + Vector3.new(0.5, 0, 0.5)
                    task.wait(0.1)
                    rootPart.CFrame = CFrame.new(oldPos)
                end)
            end
            print("🚶 Anti-AFK: Moved")
        else
            -- Rotate camera/view
            pcall(function()
                local camera = workspace.CurrentCamera
                if camera then
                    local oldCFrame = camera.CFrame
                    camera.CFrame = camera.CFrame * CFrame.Angles(0, math.rad(10), 0)
                    task.wait(0.2)
                    camera.CFrame = oldCFrame
                end
            end)
            print("👁️ Anti-AFK: Camera rotate")
        end
        
        lastAFKAction = now
    end
end

-- ========== MAIN LOOP ==========
local function startMainLoop()
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
